rules_version='2'

service cloud.firestore {
  match /databases/{database}/documents {

    // Public read for resources (language guide, etc.)
    match /resources/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // Auth-gated user data (chat history, progress, community affiliation).
    // This recursive-wildcard rule already covers the users/{userId} document
    // itself (where communityAffiliation/communityAffiliationSkipped live), so
    // those fields are owner-only by inheritance — Firestore has no field-level
    // rules, document-level owner gating is the smallest available unit.
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Knowledge base — public read, no client writes
    match /knowledge_base/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // Chat response feedback — user can only write their own rating, no client reads
    match /message_feedback/{feedbackId} {
      allow read: if false;
      allow create, update: if request.auth != null
        && request.resource.data.userId == request.auth.uid
        && feedbackId == request.auth.uid + '_' + request.resource.data.messageId;
      allow delete: if false;
    }

    // Community affiliation signup responses — written once on Save, never read
    // back by clients (Ali reviews via the Firebase console / admin tooling).
    match /community_affiliation_responses/{responseId} {
      allow read: if false;
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid;
      allow update, delete: if false;
    }
  }
}
