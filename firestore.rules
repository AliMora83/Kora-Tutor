rules_version='2'

service cloud.firestore {
  match /databases/{database}/documents {

    // Public read for resources (language guide, etc.)
    match /resources/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // Auth-gated user data (chat history, progress)
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Knowledge base — public read, no client writes
    match /knowledge_base/{docId} {
      allow read: if true;
      allow write: if false;
    }
  }
}
